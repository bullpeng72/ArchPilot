<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ legacy.name if legacy else 'ArchPilot' }} — Architecture Review</title>

  <!-- reveal.js -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@5.1.0/dist/reset.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@5.1.0/dist/reveal.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@5.1.0/dist/theme/{{ theme }}.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@5.1.0/plugin/highlight/monokai.css">

  <style>
    /* ── 전역 폰트 크기 ── */
    .reveal { font-size: 28px; }
    .reveal .slides section { text-align: left; }
    .reveal h1 { font-size: 1.8em; text-align: center; }
    .reveal h2 { font-size: 1.3em; text-align: center; margin-bottom: 0.5em; }
    .reveal h3 { font-size: 1.0em; }

    /* ── 다이어그램 컨테이너 ── */
    .diagram-wrap {
      width: 100%;
      box-sizing: border-box;
      cursor: zoom-in;
      border-radius: 8px;
      overflow: hidden;
      background: white;
      padding: 0.4rem 0.8rem;
      text-align: center; /* SVG(inline-block)를 수평 가운데 정렬 */
    }
    .diagram-wrap .mermaid { display: inline-block; }
    .diagram-hint {
      text-align: center;
      font-size: 0.55em;
      color: rgba(255,255,255,0.4);
      margin-top: 0.3em;
    }

    /* ── 다이어그램 확대 모달 ── */
    #diagram-modal {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.88);
      z-index: 9999;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 10px;
      backdrop-filter: blur(4px);
    }
    #diagram-modal.active { display: flex; }

    /* 모달 상단 툴바 (닫기 + 줌 컨트롤) */
    #diagram-modal-toolbar {
      display: flex;
      align-items: center;
      gap: 8px;
      width: min(92vw, 1100px);
      justify-content: flex-end;
    }
    .modal-zoom-btn {
      background: rgba(255,255,255,0.18);
      border: 1px solid rgba(255,255,255,0.3);
      color: #fff;
      border-radius: 6px;
      width: 32px; height: 32px;
      font-size: 1.1rem; font-weight: bold;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.15s;
      flex-shrink: 0;
    }
    .modal-zoom-btn:hover { background: rgba(255,255,255,0.35); }
    #zoom-label {
      color: #fff;
      font-size: 0.85rem;
      min-width: 46px;
      text-align: center;
      font-family: monospace;
    }
    #diagram-modal-close {
      color: #fff; font-size: 1.3rem; cursor: pointer;
      background: rgba(255,255,255,0.15); border: none;
      border-radius: 50%; width: 32px; height: 32px;
      display: flex; align-items: center; justify-content: center;
      font-weight: bold;
    }
    #diagram-modal-close:hover { background: rgba(255,255,255,0.35); }

    /* 다이어그램 뷰포트 (overflow: hidden) */
    #diagram-modal-inner {
      background: white;
      border-radius: 10px;
      width: min(92vw, 1100px);
      height: min(80vh, 750px);
      overflow: hidden;
      position: relative;
      cursor: grab;
      box-shadow: 0 8px 40px rgba(0,0,0,0.6);
    }
    #diagram-modal-inner.dragging { cursor: grabbing; }

    /* SVG 변환 캔버스 */
    #diagram-canvas {
      position: absolute;
      top: 0; left: 0;
      transform-origin: 0 0;
      user-select: none;
      -webkit-user-select: none;
    }
    #diagram-canvas svg {
      display: block;
    }

    /* 줌 힌트 */
    #diagram-modal-hint {
      color: rgba(255,255,255,0.45);
      font-size: 0.7rem;
      text-align: center;
    }

    /* ── diff 테이블 공통 ── */
    .diff-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.72em;
      table-layout: fixed;
      word-break: break-word;
    }
    .diff-table th, .diff-table td {
      padding: 6px 10px;
      white-space: normal;
      word-wrap: break-word;
    }
    .diff-table th {
      background: rgba(20,20,40,0.97);
      border-bottom: 2px solid rgba(255,255,255,0.25);
      position: sticky;
      top: 0;
      z-index: 2;
    }
    .diff-table td { border-bottom: 1px solid rgba(255,255,255,0.08); }
    .diff-table tr:hover td { background: rgba(255,255,255,0.05); }

    /* 분석 요약 테이블: 2컬럼 (항목 / 내용) */
    .summary-table th:nth-child(1), .summary-table td:nth-child(1) { width: 26%; }
    .summary-table th:nth-child(2), .summary-table td:nth-child(2) { width: 74%; }

    /* Before/After diff 테이블: 4컬럼 */
    .diff4-table th:nth-child(1), .diff4-table td:nth-child(1) { width: 34%; }
    .diff4-table th:nth-child(2), .diff4-table td:nth-child(2) { width: 12%; text-align: center; }
    .diff4-table th:nth-child(3), .diff4-table td:nth-child(3) { width: 27%; }
    .diff4-table th:nth-child(4), .diff4-table td:nth-child(4) { width: 27%; }

    /* ── Before/After 스크롤 래퍼 ── */
    .diff-scroll-wrap {
      max-height: 62vh;
      overflow-y: auto;
      overflow-x: hidden;
      border-radius: 6px;
      border: 1px solid rgba(255,255,255,0.1);
      scrollbar-width: thin;
      scrollbar-color: rgba(255,255,255,0.3) transparent;
    }
    .diff-scroll-wrap::-webkit-scrollbar { width: 6px; }
    .diff-scroll-wrap::-webkit-scrollbar-thumb {
      background: rgba(255,255,255,0.3);
      border-radius: 3px;
    }
    /* 스크롤 가능 표시 */
    .diff-scroll-hint {
      text-align: right;
      font-size: 0.55em;
      color: rgba(255,255,255,0.35);
      margin-top: 0.3em;
    }

    .tag-new  { background: #27ae60; color: white; border-radius: 3px; padding: 1px 7px; font-size: 0.85em; }
    .tag-mod  { background: #e67e22; color: white; border-radius: 3px; padding: 1px 7px; font-size: 0.85em; }
    .tag-del  { background: #e74c3c; color: white; border-radius: 3px; padding: 1px 7px; font-size: 0.85em; }
    .tag-same { background: #7f8c8d; color: white; border-radius: 3px; padding: 1px 7px; font-size: 0.85em; }

    /* ── 분석 리스트 ── */
    .reveal ul.analysis-list {
      font-size: 0.72em;
      line-height: 1.6;
      padding-left: 0 !important;   /* reveal.js 기본 padding 제거 */
      list-style: none !important;  /* 기본 bullet 제거, 아래서 대체 */
      margin: 0;
    }
    .reveal ul.analysis-list li {
      position: relative;
      padding-left: 1.1em;
      margin-bottom: 0.4em;
      border-bottom: 1px solid rgba(255,255,255,0.07);
      padding-bottom: 0.3em;
    }
    .reveal ul.analysis-list li::before {
      content: "▸";
      position: absolute;
      left: 0;
      color: rgba(255,255,255,0.5);
      font-size: 0.85em;
      line-height: 1.6;
    }

    /* ── 마이그레이션 마크다운 ── */
    .migration-wrap {
      max-height: 68vh;
      overflow-y: auto;
      padding-right: 0.4em;
      scrollbar-width: thin;
      scrollbar-color: rgba(255,255,255,0.25) transparent;
    }
    .migration-wrap::-webkit-scrollbar { width: 5px; }
    .migration-wrap::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.25); border-radius: 3px; }

    .migration-md {
      font-size: 0.68em;
      text-align: left;
      line-height: 1.65;
      color: inherit;
    }
    .migration-md h2 {
      font-size: 1.15em;
      margin: 1.1em 0 0.4em;
      padding-bottom: 0.25em;
      border-bottom: 2px solid rgba(255,255,255,0.3);
      text-align: left;
      color: #7ec8e3;
    }
    .migration-md h3 {
      font-size: 0.98em;
      margin: 0.8em 0 0.25em;
      color: #f0c040;
      text-align: left;
    }
    .migration-md h4 {
      font-size: 0.88em;
      margin: 0.6em 0 0.2em;
      color: rgba(255,255,255,0.8);
      text-align: left;
    }
    .migration-md p { margin: 0.3em 0; }
    .migration-md ul, .migration-md ol {
      padding-left: 0 !important;   /* reveal.js 중첩 padding 초기화 */
      margin: 0.2em 0;
      list-style: none !important;
    }
    .migration-md li {
      position: relative;
      padding-left: 1.0em;
      margin: 0.15em 0;
    }
    .migration-md ul li::before {
      content: "•";
      position: absolute;
      left: 0.1em;
      color: rgba(255,255,255,0.55);
    }
    .migration-md ol {
      counter-reset: md-ol;
      list-style: none !important;
    }
    .migration-md ol li {
      counter-increment: md-ol;
      padding-left: 1.4em;
    }
    .migration-md ol li::before {
      content: counter(md-ol) ".";
      position: absolute;
      left: 0;
      color: rgba(255,255,255,0.55);
      min-width: 1.2em;
      text-align: right;
    }
    /* 중첩 리스트 */
    .migration-md li > ul, .migration-md li > ol {
      margin: 0.1em 0 0.1em 0.5em;
    }
    .migration-md strong { color: #fff; font-weight: 600; }
    .migration-md em { color: rgba(255,255,255,0.75); }
    .migration-md code {
      background: rgba(255,255,255,0.14);
      padding: 1px 6px;
      border-radius: 4px;
      font-size: 0.88em;
      font-family: 'Fira Code', 'Courier New', monospace;
    }
    .migration-md pre {
      background: rgba(0,0,0,0.35);
      border-radius: 6px;
      padding: 0.6em 0.9em;
      overflow-x: auto;
      font-size: 0.9em;
    }
    .migration-md hr {
      border: none;
      border-top: 1px solid rgba(255,255,255,0.18);
      margin: 0.75em 0;
    }
    /* 테이블 가독성 개선 */
    .migration-md table {
      width: 100%;
      border-collapse: collapse;
      margin: 0.6em 0;
      font-size: 0.95em;
    }
    .migration-md thead tr {
      background: rgba(126,200,227,0.25);
    }
    .migration-md th {
      padding: 6px 12px;
      border: 1px solid rgba(255,255,255,0.25);
      text-align: left;
      font-weight: 600;
      color: #7ec8e3;
    }
    .migration-md td {
      padding: 5px 12px;
      border: 1px solid rgba(255,255,255,0.12);
    }
    .migration-md tr:nth-child(even) td {
      background: rgba(255,255,255,0.05);
    }
    .migration-md tr:hover td {
      background: rgba(255,255,255,0.09);
    }

    /* ── 뒤로 버튼 ── */
    .back-btn {
      position: fixed; top: 14px; right: 16px; z-index: 999;
      background: rgba(0,0,0,.5); color: #fff;
      border: 1px solid rgba(255,255,255,.3);
      border-radius: 6px; padding: 5px 12px; font-size: 11px;
      cursor: pointer; text-decoration: none; backdrop-filter: blur(4px);
    }
    .back-btn:hover { background: rgba(0,0,0,.75); }
  </style>
</head>
<body>
<a class="back-btn" href="/" title="인터랙티브 앱으로 돌아가기">← 앱으로</a>

<!-- 다이어그램 확대 모달 -->
<div id="diagram-modal">
  <div id="diagram-modal-toolbar">
    <button class="modal-zoom-btn" id="btn-zoom-out" title="축소 (−)">−</button>
    <span id="zoom-label">100%</span>
    <button class="modal-zoom-btn" id="btn-zoom-in" title="확대 (+)">+</button>
    <button class="modal-zoom-btn" id="btn-zoom-reset" title="원래 크기로 (R)" style="font-size:0.85rem;">↺</button>
    <button id="diagram-modal-close" title="닫기 (ESC)">✕</button>
  </div>
  <div id="diagram-modal-inner">
    <div id="diagram-canvas"></div>
  </div>
  <div id="diagram-modal-hint">휠: 줌 &nbsp;|&nbsp; 드래그: 이동 &nbsp;|&nbsp; ↺: 원래 크기 &nbsp;|&nbsp; ESC: 닫기</div>
</div>

<div class="reveal">
<div class="slides">

{# ── 슬라이드 1: 표지 ──────────────────────────────────────────────── #}
<section>
  <h1>🏗️ Architecture Review</h1>
  {% if legacy %}
  <h3 style="text-align:center; margin-top:0.6em;">{{ legacy.name }}</h3>
  <p style="text-align:center; color: #aaa; font-size:0.75em;">{{ legacy.description }}</p>
  {% endif %}
  <br>
  <p style="text-align:center; font-size:0.6em; color:#777;">
    Generated by <strong>ArchPilot</strong>
  </p>
</section>

{# ── 슬라이드 2: Legacy 아키텍처 ──────────────────────────────────── #}
{% if legacy_mermaid %}
<section>
  <h2>📦 현재 시스템 (Legacy)</h2>
  {% if legacy %}
  <p style="text-align:center; font-size:0.6em; color:#aaa; margin-bottom:0.5em;">
    컴포넌트 {{ legacy.components|length }}개 &nbsp;·&nbsp; 연결 {{ legacy.connections|length }}개
  </p>
  {% endif %}
  <div class="diagram-wrap" data-diagram>
    <div class="mermaid" style="">
{{ legacy_mermaid | safe }}
    </div>
  </div>
  <p class="diagram-hint">클릭하면 확대됩니다</p>
</section>
{% endif %}

{# ── 슬라이드 3: 분석 결과 ────────────────────────────────────────── #}
{% if analysis %}
<section>
  <section>
    <h2>🔍 분석 결과 요약</h2>
    <p style="font-size:0.75em; margin-bottom:0.7em;">{{ analysis.summary }}</p>
    <table class="diff-table summary-table">
      <tr><th>항목</th><th>내용</th></tr>
      {% if analysis.health_score is defined %}
      <tr><td>시스템 건강도</td><td><strong>{{ analysis.health_score }}/100</strong></td></tr>
      {% endif %}
      <tr><td>예상 공수</td><td><strong>{{ analysis.estimated_effort.value }}</strong></td></tr>
      <tr><td>주요 문제점</td><td>{{ analysis.pain_points|length }}건</td></tr>
      <tr><td>기술 부채</td><td>{{ analysis.tech_debt|length }}건</td></tr>
      <tr><td>위험 영역</td><td>{{ analysis.risk_areas|length }}건</td></tr>
      {% if analysis.compliance_gaps %}
      <tr><td>규제 갭</td><td style="color:#c0392b;">{{ analysis.compliance_gaps|length }}건</td></tr>
      {% endif %}
      {% if analysis.security_findings %}
      <tr><td>보안 취약점</td><td style="color:#c0392b;">{{ analysis.security_findings|length }}건</td></tr>
      {% endif %}
      <tr><td>권장 패턴</td><td>{{ analysis.recommended_patterns[:3]|join(' / ') }}</td></tr>
    </table>
  </section>

  {% if analysis.pain_points %}
  <section>
    <h2>⚠️ 주요 문제점</h2>
    <ul class="analysis-list">
      {% for p in analysis.pain_points %}
      <li>{{ p }}</li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  {% if analysis.tech_debt %}
  <section>
    <h2>🔧 기술 부채</h2>
    <ul class="analysis-list">
      {% for td in analysis.tech_debt %}
      <li><strong>[{{ td.severity|upper }}] {{ td.component_id }}</strong>: {{ td.description }}</li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  {% if analysis.compliance_gaps or analysis.security_findings %}
  <section>
    {% if analysis.compliance_gaps %}
    <h2>📋 규제 컴플라이언스 갭</h2>
    <ul class="analysis-list">
      {% for g in analysis.compliance_gaps %}
      <li>{{ g }}</li>
      {% endfor %}
    </ul>
    {% endif %}
    {% if analysis.security_findings %}
    <h2 style="margin-top:0.8em;">🔒 보안 취약점</h2>
    <ul class="analysis-list">
      {% for f in analysis.security_findings %}
      <li>{{ f }}</li>
      {% endfor %}
    </ul>
    {% endif %}
  </section>
  {% endif %}

  {% if analysis.risk_areas %}
  <section>
    <h2>🚨 위험 영역</h2>
    <ul class="analysis-list">
      {% for r in analysis.risk_areas %}
      <li><strong>{{ r.component_id }}</strong>: {{ r.risk }}<br>
          <em style="font-size:0.85em; color:#aaa;">{{ r.mitigation }}</em></li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  {% if analysis.modernization_opportunities %}
  <section>
    <h2>💡 현대화 기회</h2>
    <ul class="analysis-list">
      {% for opp in analysis.modernization_opportunities %}
      <li><strong>[P{{ opp.priority }}] {{ opp.area }}</strong>: {{ opp.description }}</li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}
</section>
{% endif %}

{# ── 슬라이드 4: 현대화 아키텍처 ─────────────────────────────────── #}
{% if modern_mermaid %}
<section>
  <h2>🚀 현대화 시스템</h2>
  {% if modern %}
  <p style="text-align:center; font-size:0.6em; color:#aaa; margin-bottom:0.5em;">
    컴포넌트 {{ modern.components|length }}개 &nbsp;·&nbsp; 연결 {{ modern.connections|length }}개
  </p>
  {% endif %}
  <div class="diagram-wrap" data-diagram>
    <div class="mermaid" style="">
{{ modern_mermaid | safe }}
    </div>
  </div>
  <p class="diagram-hint">클릭하면 확대됩니다</p>
</section>
{% endif %}

{# ── 슬라이드 5: Before / After 비교 ─────────────────────────────── #}
{% if diff %}
<section>
  <h2>📊 Before / After 비교</h2>
  <div class="diff-scroll-wrap">
    <table class="diff-table diff4-table">
      <thead>
        <tr>
          <th>컴포넌트</th>
          <th>변경</th>
          <th>Legacy</th>
          <th>Modern</th>
        </tr>
      </thead>
      <tbody>
        {% for c in diff.added %}
        <tr>
          <td>{{ c.label }}</td>
          <td><span class="tag-new">NEW</span></td>
          <td style="color:rgba(255,255,255,0.35);">—</td>
          <td>{{ c.tech|join(', ') or c.type.value }}</td>
        </tr>
        {% endfor %}
        {% for ch in diff.modified %}
        <tr>
          <td>{{ ch.after.label }}</td>
          <td><span class="tag-mod">변경</span></td>
          <td style="text-decoration:line-through; color:rgba(255,255,255,0.5);">{{ ch.before.tech|join(', ') or ch.before.host.value }}</td>
          <td>{{ ch.after.tech|join(', ') or ch.after.host.value }}</td>
        </tr>
        {% endfor %}
        {% for c in diff.unchanged %}
        <tr>
          <td>{{ c.label }}</td>
          <td><span class="tag-same">유지</span></td>
          <td colspan="2" style="color:rgba(255,255,255,0.6);">{{ c.tech|join(', ') }}</td>
        </tr>
        {% endfor %}
        {% for c in diff.removed %}
        <tr>
          <td style="text-decoration:line-through; color:rgba(255,255,255,0.5);">{{ c.label }}</td>
          <td><span class="tag-del">제거</span></td>
          <td>{{ c.tech|join(', ') }}</td>
          <td style="color:rgba(255,255,255,0.35);">—</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  <p class="diff-scroll-hint">↕ 스크롤하여 전체 내용 확인</p>
</section>
{% endif %}

{# ── 슬라이드 6: 마이그레이션 로드맵 ─────────────────────────────── #}
{% if migration_plan %}
<section>
  <h2>🗺️ 마이그레이션 로드맵</h2>
  <div class="migration-wrap">
    <div class="migration-md" id="migration-md"></div>
  </div>
  <script id="migration-src" type="text/plain">{{ migration_plan | safe }}</script>
</section>
{% endif %}

{# ── 슬라이드 7: 마무리 ────────────────────────────────────────────── #}
<section>
  <h2 style="text-align:center;">감사합니다</h2>
  <p style="text-align:center; color:#aaa; font-size:0.75em;">
    Generated by <strong>ArchPilot</strong> &nbsp;·&nbsp;
    <code>pip install archpilot</code>
  </p>
</section>

</div>
</div>

<!-- reveal.js -->
<script src="https://cdn.jsdelivr.net/npm/reveal.js@5.1.0/dist/reveal.js"></script>
<script src="https://cdn.jsdelivr.net/npm/reveal.js@5.1.0/plugin/highlight/highlight.js"></script>
<script src="https://cdn.jsdelivr.net/npm/reveal.js@5.1.0/plugin/notes/notes.js"></script>
<!-- mermaid.js -->
<script src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
<!-- marked.js — 마이그레이션 플랜 마크다운 렌더링 -->
<script src="https://cdn.jsdelivr.net/npm/marked@12/marked.min.js"></script>
<script>
  mermaid.initialize({ startOnLoad: false, theme: 'default', securityLevel: 'loose' });

  Reveal.initialize({
    hash: true,
    slideNumber: 'c/t',
    transition: 'slide',
    width: 1280,
    height: 720,
    margin: 0.06,
    minScale: 0.2,
    maxScale: 2.0,
    plugins: [RevealHighlight, RevealNotes],
  });

  // ── 슬라이드 전환 시 mermaid 렌더링 ──────────────────────────────────
  async function renderCurrentSlide(slide) {
    if (!slide) return;
    const nodes = Array.from(slide.querySelectorAll('.mermaid:not([data-processed])'));
    if (!nodes.length) return;
    try {
      await mermaid.run({ nodes });
      // 렌더링 완료 후 SVG 크기를 제한한다.
      // font-size 없이 자연 크기로 렌더링 후 슬라이드 높이에 맞게 축소.
      // width: 100% + max-height + height: auto → 비율 유지하며 슬라이드에 맞게 조정.
      nodes.forEach(n => {
        const svg = n.querySelector('svg');
        if (!svg) return;
        const vb = svg.viewBox && svg.viewBox.baseVal;
        if (!vb || vb.width <= 0 || vb.height <= 0) {
          // viewBox 없을 때 안전 폴백
          svg.style.maxWidth = '100%';
          svg.style.height   = 'auto';
          svg.style.display  = 'block';
          return;
        }
        // viewBox 비율을 유지하면서 슬라이드에 맞는 픽셀 크기를 계산한다.
        // CSS width:auto/max-width:100% 조합은 flex 컨텍스트에서 순환 참조를
        // 유발할 수 있으므로 JS에서 명시적 픽셀 값을 직접 지정한다.
        const aspect = vb.width / vb.height;
        const maxH   = window.innerHeight * 0.54;
        const wrap   = n.closest('.diagram-wrap');
        const avail  = wrap ? (wrap.clientWidth - 20) : (window.innerWidth * 0.88);
        let w = vb.width, h = vb.height;
        if (h > maxH) { h = maxH; w = h * aspect; }
        if (w > avail) { w = avail; h = w / aspect; }
        // mermaid 인라인 스타일(max-width:XXXpx) 초기화 후 명시적 크기 설정
        svg.style.cssText  = 'display: block;';
        svg.setAttribute('width',  Math.round(w));
        svg.setAttribute('height', Math.round(h));
      });
    } catch (e) {
      nodes.forEach(n => {
        if (!n.querySelector('svg')) {
          n.innerHTML = '<p style="color:#e74c3c;font-size:.8em;">다이어그램 렌더링 오류: ' + e.message + '</p>';
        }
      });
    }
  }

  Reveal.on('ready',        async (e) => renderCurrentSlide(e.currentSlide));
  Reveal.on('slidechanged', async (e) => renderCurrentSlide(e.currentSlide));

  // ── 다이어그램 확대 모달 (줌 + 패닝) ────────────────────────────────
  const modal      = document.getElementById('diagram-modal');
  const modalInner = document.getElementById('diagram-modal-inner');
  const canvas     = document.getElementById('diagram-canvas');
  const modalClose = document.getElementById('diagram-modal-close');
  const zoomLabel  = document.getElementById('zoom-label');
  const btnZoomIn  = document.getElementById('btn-zoom-in');
  const btnZoomOut = document.getElementById('btn-zoom-out');
  const btnReset   = document.getElementById('btn-zoom-reset');

  // 줌/패닝 상태
  let _scale = 1, _panX = 0, _panY = 0;
  let _isDragging = false, _dragStartX = 0, _dragStartY = 0, _panStartX = 0, _panStartY = 0;
  const SCALE_MIN = 0.1, SCALE_MAX = 12;

  function _applyTransform() {
    canvas.style.transform = `translate(${_panX}px,${_panY}px) scale(${_scale})`;
    zoomLabel.textContent  = Math.round(_scale * 100) + '%';
  }

  // 뷰포트 중심점 (cx,cy) 기준으로 delta 배율 줌
  function _zoomAt(cx, cy, delta) {
    const next = Math.max(SCALE_MIN, Math.min(SCALE_MAX, _scale * delta));
    const ratio = next / _scale;
    _panX  = cx - ratio * (cx - _panX);
    _panY  = cy - ratio * (cy - _panY);
    _scale = next;
    _applyTransform();
  }

  // SVG를 뷰포트에 꽉 맞게 초기 fit
  // getBBox()로 실제 콘텐츠 영역만 사용 (Mermaid SVG의 여백 무시)
  function _fitToView() {
    const svg = canvas.querySelector('svg');
    if (!svg) return;

    // SVG 속성 크기 (CSS px)
    const attrW = parseFloat(svg.getAttribute('width'))  || 0;
    const attrH = parseFloat(svg.getAttribute('height')) || 0;
    const vb    = svg.viewBox && svg.viewBox.baseVal;
    const vbW   = (vb && vb.width  > 0) ? vb.width  : attrW || 800;
    const vbH   = (vb && vb.height > 0) ? vb.height : attrH || 600;
    // SVG 실제 렌더 크기 (CSS px) — 속성값이 viewBox 단위와 같을 때 동일
    const cssW  = attrW || vbW;
    const cssH  = attrH || vbH;
    // SVG 유저 단위 → CSS px 비율
    const ux = cssW / vbW;
    const uy = cssH / vbH;

    // 실제 콘텐츠 Bounding-Box (SVG 유저 단위)
    let cX = 0, cY = 0, cW = cssW, cH = cssH;
    try {
      const bbox = svg.getBBox();
      if (bbox.width > 4 && bbox.height > 4) {
        cX = bbox.x * ux;
        cY = bbox.y * uy;
        cW = bbox.width  * ux;
        cH = bbox.height * uy;
      }
    } catch (_) { /* SVG 미렌더링 시 폴백 */ }

    const vpW = modalInner.clientWidth;
    const vpH = modalInner.clientHeight;
    const pad = 24;
    _scale = Math.min((vpW - pad) / cW, (vpH - pad) / cH, 3);
    // 콘텐츠 중심을 뷰포트 중심에 정렬
    _panX = vpW / 2 - (cX + cW / 2) * _scale;
    _panY = vpH / 2 - (cY + cH / 2) * _scale;
    _applyTransform();
  }

  function openDiagramModal(wrap) {
    const svg = wrap.querySelector('svg');
    if (!svg) return;
    const clone = svg.cloneNode(true);
    clone.style.cssText = '';   // 슬라이드용 인라인 스타일 초기화
    canvas.innerHTML = '';
    canvas.appendChild(clone);
    modal.classList.add('active');
    // 모달 표시 + 레이아웃 확정 후 fit (두 번 rAF + 짧은 타임아웃 이중 보장)
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        _fitToView();
        // 레이아웃이 아직 미확정인 경우 한 번 더
        if (_scale <= 0.01) setTimeout(_fitToView, 60);
      });
    });
  }

  function closeDiagramModal() {
    modal.classList.remove('active');
    modalInner.classList.remove('dragging');
    canvas.innerHTML = '';
    _scale = 1; _panX = 0; _panY = 0;
    _applyTransform();
  }

  // 마우스 휠 줌 (뷰포트 상대 좌표 기준)
  modalInner.addEventListener('wheel', (e) => {
    e.preventDefault();
    const rect  = modalInner.getBoundingClientRect();
    const cx    = e.clientX - rect.left;
    const cy    = e.clientY - rect.top;
    const delta = e.deltaY < 0 ? 1.12 : 1 / 1.12;
    _zoomAt(cx, cy, delta);
  }, { passive: false });

  // 드래그 패닝
  modalInner.addEventListener('mousedown', (e) => {
    if (e.button !== 0) return;
    _isDragging = true;
    _dragStartX = e.clientX; _dragStartY = e.clientY;
    _panStartX  = _panX;     _panStartY  = _panY;
    modalInner.classList.add('dragging');
    e.preventDefault();
  });
  window.addEventListener('mousemove', (e) => {
    if (!_isDragging) return;
    _panX = _panStartX + (e.clientX - _dragStartX);
    _panY = _panStartY + (e.clientY - _dragStartY);
    _applyTransform();
  });
  window.addEventListener('mouseup', () => {
    if (_isDragging) {
      _isDragging = false;
      modalInner.classList.remove('dragging');
    }
  });

  // 터치 줌/패닝 (pinch-to-zoom)
  let _touch1 = null, _touch2 = null, _touchScale0 = 1, _touchPanX0 = 0, _touchPanY0 = 0;
  modalInner.addEventListener('touchstart', (e) => {
    if (e.touches.length === 1) {
      _touch1 = e.touches[0]; _touch2 = null;
      _panStartX = _panX; _panStartY = _panY;
    } else if (e.touches.length === 2) {
      _touch1 = e.touches[0]; _touch2 = e.touches[1];
      _touchScale0 = _scale;
      _touchPanX0 = _panX; _touchPanY0 = _panY;
    }
    e.preventDefault();
  }, { passive: false });
  modalInner.addEventListener('touchmove', (e) => {
    e.preventDefault();
    if (e.touches.length === 1 && _touch1 && !_touch2) {
      _panX = _panStartX + (e.touches[0].clientX - _touch1.clientX);
      _panY = _panStartY + (e.touches[0].clientY - _touch1.clientY);
      _applyTransform();
    } else if (e.touches.length === 2 && _touch1 && _touch2) {
      const d0 = Math.hypot(_touch2.clientX - _touch1.clientX, _touch2.clientY - _touch1.clientY);
      const d1 = Math.hypot(e.touches[1].clientX - e.touches[0].clientX, e.touches[1].clientY - e.touches[0].clientY);
      const cx = (e.touches[0].clientX + e.touches[1].clientX) / 2 - modalInner.getBoundingClientRect().left;
      const cy = (e.touches[0].clientY + e.touches[1].clientY) / 2 - modalInner.getBoundingClientRect().top;
      _scale = Math.max(SCALE_MIN, Math.min(SCALE_MAX, _touchScale0 * (d1 / d0)));
      _panX  = cx - (_touchPanX0 - cx) * (_scale / _touchScale0) - cx + cx;
      _panX  = cx - (cx - _touchPanX0) * (_scale / _touchScale0);
      _panY  = cy - (cy - _touchPanY0) * (_scale / _touchScale0);
      _applyTransform();
    }
  }, { passive: false });

  // 줌 버튼
  function _centerZoom(delta) {
    _zoomAt(modalInner.clientWidth / 2, modalInner.clientHeight / 2, delta);
  }
  btnZoomIn .addEventListener('click', (e) => { e.stopPropagation(); _centerZoom(1.25); });
  btnZoomOut.addEventListener('click', (e) => { e.stopPropagation(); _centerZoom(1 / 1.25); });
  btnReset  .addEventListener('click', (e) => { e.stopPropagation(); _fitToView(); });

  // 슬라이드 다이어그램 클릭 → 모달 열기
  document.addEventListener('click', (e) => {
    if (modal.classList.contains('active')) return;
    const wrap = e.target.closest('[data-diagram]');
    if (wrap) openDiagramModal(wrap);
  });

  modalClose.addEventListener('click', (e) => { e.stopPropagation(); closeDiagramModal(); });

  // 모달 배경(오버레이) 클릭 → 닫기
  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeDiagramModal();
  });

  // 키보드 단축키
  document.addEventListener('keydown', (e) => {
    if (!modal.classList.contains('active')) return;
    if (e.key === 'Escape')   closeDiagramModal();
    if (e.key === '='  || e.key === '+') _centerZoom(1.25);
    if (e.key === '-')                   _centerZoom(1 / 1.25);
    if (e.key === 'r'  || e.key === 'R') _fitToView();
  });

  // ── 마이그레이션 플랜 마크다운 렌더링 ───────────────────────────────
  (function renderMigrationMarkdown() {
    const src    = document.getElementById('migration-src');
    const target = document.getElementById('migration-md');
    if (!src || !target) return;
    // marked v9+: setOptions 대신 parse() 두 번째 인자로 옵션 전달
    target.innerHTML = marked.parse(src.textContent.trim(), { breaks: true, gfm: true });
  })();
</script>
</body>
</html>
