    get currentMmd() {
      return this.diagramTab === 'legacy' ? this.state.legacy_mmd : this.state.modern_mmd;
    },

    // ── 초기화 ────────────────────────────────────────────────────────
    async init() {
      // 저장된 테마 적용 (FOUC 방지 스크립트와 동기화)
      const saved = localStorage.getItem('archpilot-theme') || 'light';
      this.isDark = saved === 'dark';

      // 서버 세션 복구
      try {
        const res = await fetch('/api/state');
        this.state = await res.json();
        // multi_perspective는 analysis 내부에 저장됨 — 별도 필드로 복원
        if (!this.state.multi_perspective && this.state.analysis?.multi_perspective) {
          this.state.multi_perspective = this.state.analysis.multi_perspective;
        }
        // design_perspective는 session.to_dict()에서 최상위로 전달됨
        // (이미 state에 포함되어 있으므로 별도 처리 불필요)
        this.requirements = this.state.requirements || '';
        this.scenario     = this.state.scenario || null;
        this.activeStep   = Math.min(this.state.step, 4);
        if (this.state.modern && this.state.system) {
          this.diff    = computeDiff(this.state.system, this.state.modern);
          this.infoTab = 'diff';
        }
        if (this.state.system) this.renderDiagram();
      } catch (e) { /* 첫 실행 시 무시 */ }

      // draw.io 메시지 핸들러 등록 (한 번만)
      this._initDrawioMessages();

      // 편집 탭 전환 시 XML 로드 + CodeMirror 초기화
      this.$watch('inputMode', (val) => {
        if (val === 'structured') {
          this.$nextTick(() => this._initCodeMirror());
        }
        if (val === 'draw' && this.drawioReady) {
          this._loadXmlIntoDrawio();
        }
      });
    },

    // ── 테마 토글 ──────────────────────────────────────────────────────
    async toggleTheme() {
      this.isDark = !this.isDark;
      const theme = this.isDark ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('archpilot-theme', theme);
      // CodeMirror 테마 동기화
      if (this._cmEditor && this._themeCompartment) {
        const { oneDark } = await import('@codemirror/theme-one-dark').catch(() => ({ oneDark: [] }));
        this._cmEditor.dispatch({
          effects: this._themeCompartment.reconfigure(this.isDark ? oneDark : []),
        });
      }
    },

    // ── 다이어그램 렌더링 ──────────────────────────────────────────────
    async renderDiagram() {
      const mmd = this.currentMmd;
      const wrapper = document.getElementById('mermaid-canvas');
      if (!wrapper || !mmd) return;
      try {
        const uid = `g${Date.now()}`;
        const { svg } = await mermaid.render(uid, mmd);
        wrapper.innerHTML = svg;

        // Mermaid가 SVG에 추가하는 max-width 인라인 스타일 제거 후
        // viewBox 자연 크기로 명시 설정 → 고해상도 벡터 렌더링 보장
        const svgEl = wrapper.querySelector('svg');
        if (svgEl) {
          svgEl.style.maxWidth = 'none';
          svgEl.removeAttribute('width');
          svgEl.removeAttribute('height');
          const vb = svgEl.getAttribute('viewBox');
          if (vb) {
            const parts = vb.trim().split(/[\s,]+/).map(Number);
            const w = parts[2], h = parts[3];
            if (w > 0 && h > 0) {
              svgEl.setAttribute('width',  w);
              svgEl.setAttribute('height', h);
            }
          }
        }

        this.fitDiagram();
      } catch (err) {
        wrapper.innerHTML =
          `<div style="color:var(--danger);padding:12px;font-size:13px;">
             렌더링 오류: ${err.message}
           </div>`;
      }
    },

    // ── 팬/줌 ──────────────────────────────────────────────────────────
    onWheel(e) {
      const factor = e.deltaY < 0 ? 1.12 : 1 / 1.12;
      const rect = e.currentTarget.getBoundingClientRect();
      const mx = e.clientX - rect.left;
      const my = e.clientY - rect.top;
      const newZoom = Math.min(Math.max(this.zoom * factor, 0.08), 8);
      // 커서 위치 기준으로 줌
      this.panX = mx - (mx - this.panX) * (newZoom / this.zoom);
      this.panY = my - (my - this.panY) * (newZoom / this.zoom);
      this.zoom = newZoom;
    },
    startPan(e) {
      if (e.button !== 0) return;
      this.isPanning = true;
      this._panStart = { x: e.clientX - this.panX, y: e.clientY - this.panY };
    },
    doPan(e) {
      if (!this.isPanning) return;
      this.panX = e.clientX - this._panStart.x;
      this.panY = e.clientY - this._panStart.y;
    },
    endPan() { this.isPanning = false; },
    zoomIn()  { this._applyZoom(1.25); },
    zoomOut() { this._applyZoom(0.8); },
    _applyZoom(factor) {
      const canvas = this.$refs.diagramCanvas;
      if (!canvas) return;
      const cx = canvas.clientWidth  / 2;
      const cy = canvas.clientHeight / 2;
      const newZoom = Math.min(Math.max(this.zoom * factor, 0.08), 8);
      this.panX = cx - (cx - this.panX) * (newZoom / this.zoom);
      this.panY = cy - (cy - this.panY) * (newZoom / this.zoom);
      this.zoom = newZoom;
    },
    fitDiagram() {
      this.$nextTick(() => {
        const canvas  = this.$refs.diagramCanvas;
        const wrapper = document.getElementById('mermaid-canvas');
        if (!canvas || !wrapper) return;
        const cw = canvas.clientWidth;
        const ch = canvas.clientHeight;
        const ww = wrapper.scrollWidth;
        const wh = wrapper.scrollHeight;
        if (!ww || !wh) return;
        const pad   = 32;
        const scale = Math.min((cw - pad) / ww, (ch - pad) / wh, 1.5);
        this.zoom = scale;
        this.panX = (cw - ww * scale) / 2;
        this.panY = (ch - wh * scale) / 2;
      });
    },

    // ── 탭 전환 ────────────────────────────────────────────────────────
    switchTab(tab) {
      this.diagramTab = tab;
      this.$nextTick(() => this.renderDiagram());
    },

    // ── 단계 이동 ──────────────────────────────────────────────────────
    goStep(i) {
      if (i !== 0 && this.state.step < i) return;
      this.activeStep = i;
      this.diagramTab = i >= 3 ? 'modern' : 'legacy';
      if (i === 4) this.infoTab = 'diff';
      this.$nextTick(() => this.renderDiagram());
    },

    // ── 도움말 & YAML 템플릿 ────────────────────────────────────────────
    openHelp(tab = 'input') {
      this.helpTab  = tab;
      this.showHelp = true;
    },
    loadTemplate() {
      this.inputText = this.YAML_TEMPLATE;
      this.inputMode = 'structured';
      this._syncEditorContent(this.YAML_TEMPLATE);
    },

    // ── draw.io 편집 ────────────────────────────────────────────────────
    _EMPTY_DRAWIO: '<mxGraphModel><root>'
      + '<mxCell id="0"/><mxCell id="1" parent="0"/>'
      + '<mxCell id="group_on_premise" value="On-Premise" style="swimlane;startSize=20;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">'
      + '<mxGeometry x="40" y="40" width="600" height="200" as="geometry"/></mxCell>'
      + '</root></mxGraphModel>',

    openDrawMode() {
      this.inputMode = 'draw';
      // iframe이 이미 ready면 즉시 XML 로드, 아니면 init 이벤트 대기
      if (this.drawioReady) this._loadXmlIntoDrawio();
    },

    onDrawioFrameLoad() {
      // iframe src 로드 완료 — diagrams.net의 'init' postMessage를 기다림
      this.drawioReady = false;
    },

    _loadXmlIntoDrawio() {
      const frame = this.$refs.drawioFrame;
      if (!frame) return;
      const xml = this.state.legacy_drawio || this._EMPTY_DRAWIO;
      frame.contentWindow.postMessage(
        JSON.stringify({ action: 'load', autosave: 1, xml }),
        '*'
      );
    },

    _initDrawioMessages() {
      window.addEventListener('message', (e) => {
        if (!e.data || typeof e.data !== 'string') return;
        let msg;
        try { msg = JSON.parse(e.data); } catch { return; }

        const frame = this.$refs.drawioFrame;
        if (!frame || e.source !== frame.contentWindow) return;

        if (msg.event === 'init') {
          this.drawioReady = true;
          this._injectDrawioLibrary(frame);
          if (this.inputMode === 'draw' && this.activeStep === 0) {
            this._loadXmlIntoDrawio();
          }
        } else if (msg.event === 'save') {
          this._onDrawioSave(msg.xml);
        } else if (msg.event === 'autosave') {
          // 자동저장은 반영하지 않음 (명시적 Save만 처리)
        } else if (msg.event === 'exit') {
          this.inputMode = 'structured';
        }
      });
    },

    async copyShapeStyle(style, name) {
      try {
        await navigator.clipboard.writeText(style);
        this.toast('info', `📋 ${name} 스타일 복사 완료 — 편집기에서 도형 우클릭 → Edit Style → 붙여넣기`);
      } catch {
        this.toast('error', '클립보드 복사에 실패했습니다. HTTPS 환경에서 실행해 주세요.');
      }
    },

    async _initCodeMirror() {
      if (this._cmEditor) return;  // 이미 초기화됨
      const el = this.$refs.cmEditorEl;
      if (!el) return;

      try {
        const { EditorView, keymap, lineNumbers, highlightActiveLine,
                drawSelection, dropCursor, rectangularSelection,
                crosshairCursor, highlightSpecialChars } = await import('@codemirror/view');
        const { EditorState, Compartment }               = await import('@codemirror/state');
        const { history, defaultKeymap, historyKeymap,
                indentWithTab }                          = await import('@codemirror/commands');
        const { indentOnInput, syntaxHighlighting,
                defaultHighlightStyle, bracketMatching } = await import('@codemirror/language');
        const { yaml }                                   = await import('@codemirror/lang-yaml');
        const { linter, lintGutter, lintKeymap }         = await import('@codemirror/lint');
        const { oneDark }                                = await import('@codemirror/theme-one-dark');

        this._themeCompartment = new Compartment();

        const yamlLinter = linter((view) => {
          if (typeof jsyaml === 'undefined') return [];
          const text = view.state.doc.toString();
          try {
            jsyaml.load(text);
            this.cmError = '';
            return [];
          } catch (e) {
            this.cmError = e.reason || e.message || 'YAML 오류';
            const pos = e.mark?.position ?? 0;
            return [{ from: Math.min(pos, text.length), to: Math.min(pos + 1, text.length),
                      severity: 'error', message: this.cmError }];
          }
        }, { delay: 400 });

        const ingestKeymap = keymap.of([{
          key: 'Ctrl-Enter', mac: 'Cmd-Enter',
          run: () => { if (this.inputText.trim() && !this.loading) this.ingest(); return true; },
        }]);

        const onChange = EditorView.updateListener.of((update) => {
          if (update.docChanged) this.inputText = update.state.doc.toString();
        });

        this._cmEditor = new EditorView({
          state: EditorState.create({
            doc: this.inputText,
            extensions: [
              highlightSpecialChars(), history(), drawSelection(), dropCursor(),
              rectangularSelection(), crosshairCursor(), indentOnInput(),
              syntaxHighlighting(defaultHighlightStyle, { fallback: true }),
              bracketMatching(), lineNumbers(), highlightActiveLine(),
              yaml(), yamlLinter, lintGutter(),
              keymap.of([...defaultKeymap, ...historyKeymap, indentWithTab, ...lintKeymap]),
              ingestKeymap, onChange,
              this._themeCompartment.of(this.isDark ? oneDark : []),
              EditorView.theme({
                '&': { height: '100%', fontSize: '12.5px' },
                '.cm-scroller': { fontFamily: '"SF Mono","Fira Code","Consolas",monospace', overflow: 'auto' },
              }),
            ],
          }),
          parent: el,
        });
      } catch (err) {
        console.warn('CodeMirror 로드 실패, textarea 폴백:', err);
        // 폴백: 일반 textarea 렌더링 (el에 직접 삽입)
        el.innerHTML = '<textarea style="width:100%;height:100%;border:none;padding:6px;font-family:monospace;font-size:12px;background:transparent;color:inherit;outline:none;resize:none;"></textarea>';
        const ta = el.querySelector('textarea');
        ta.value = this.inputText;
        ta.addEventListener('input', () => { this.inputText = ta.value; });
      }
    },

    _syncEditorContent(text) {
      if (!this._cmEditor) return;
      this._cmEditor.dispatch({
        changes: { from: 0, to: this._cmEditor.state.doc.length, insert: text },
      });
    },

    _injectDrawioLibrary(frame) {
      // init 이후 openLibrary 액션으로 ArchPilot 커스텀 라이브러리를 사이드바에 추가.
      const entries = this._DRAWIO_CONFIG.libraries[0].entries.map(e => ({
        xml: e.xml, w: e.w, h: e.h, title: e.title,
      }));
      const libXml = `<mxlibrary>${JSON.stringify(entries)}</mxlibrary>`;
      frame.contentWindow.postMessage(
        JSON.stringify({ action: 'openLibrary', name: 'ArchPilot', xml: libXml }),
        '*'
      );
    },

    async _onDrawioSave(xml) {
      if (!xml) return;
      this.drawioSaving = true;
      try {
        const res = await fetch('/api/ingest/drawio', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ xml, system_name: this.state.system?.name || 'Imported System' }),
        });
        if (!res.ok) {
          const err = await res.json().catch(() => ({ detail: `HTTP ${res.status}` }));
          throw new Error(err.detail || '파싱 실패');
        }
        const data = await res.json();
        Object.assign(this.state, {
          system: data.system, legacy_mmd: data.legacy_mmd,
          legacy_drawio: data.legacy_drawio, step: 1,
          analysis: null, modern: null, modern_mmd: '',
        });
        this.diff = null;
        this.activeStep = 1;
        this.inputMode = 'structured';
        this.diagramTab = 'legacy';
        this.infoTab = 'summary';
        this.toast('success', `✅ ${data.system.name} — ${data.system.components.length}개 컴포넌트 반영 완료`);
        this.$nextTick(() => this.renderDiagram());
      } catch (e) {
        this.toast('error', `편집 반영 실패: ${e.message}`);
      } finally {
        this.drawioSaving = false;
      }
    },

    // ── AI 채팅 ─────────────────────────────────────────────────────────
    exportChatToYaml() {
      if (!this.chatExtractedSystem) return;
      const sys = { ...this.chatExtractedSystem };
      delete sys.__system__;
      let yamlText;
      try {
        yamlText = jsyaml.dump(sys, { indent: 2, lineWidth: 80, noRefs: true });
      } catch {
        yamlText = JSON.stringify(sys, null, 2);
      }
      this.inputText = yamlText;
      this.inputMode = 'structured';
      this._syncEditorContent(yamlText);
      this.toast('success', '📄 구조화 탭에 YAML이 삽입되었습니다. 내용을 확인·수정 후 분석하세요.');
    },

    async sendChat() {
      const text = this.chatInput.trim();
      if (!text || this.chatLoading) return;
      this.chatMessages.push({ role: 'user', content: text });
      this.chatInput = '';
      this.chatLoading = true;
      this.chatTypingText = '';
      this.$nextTick(() => {
        const el = this.$refs.chatMessages;
        if (el) el.scrollTop = el.scrollHeight;
      });

      let systemReady = false;
      try {
        await this.consumeStream(
          '/api/chat/ingest/stream',
          { messages: this.chatMessages },
          async (d) => {
            if (d.type === 'chunk') {
              this.chatTypingText += d.text;
              this.$nextTick(() => {
                const el = this.$refs.chatMessages;
                if (el) el.scrollTop = el.scrollHeight;
              });
            } else if (d.type === 'system_ready') {
              this.chatExtractedSystem = d.system;
              this.chatExtractedMmd = d.legacy_mmd;
              this.chatExtractedDrawio = d.legacy_drawio || '';
              this.chatMessages.push({
                role: 'assistant',
                content: '✅ 시스템 구성이 완성되었습니다! 아래 버튼으로 다이어그램을 생성하세요.',
              });
              systemReady = true;
            } else if (d.type === 'reply') {
              // chunks already accumulated in chatTypingText
            } else if (d.type === 'error') {
              throw new Error(d.msg);
            }
          }
        );
        if (!systemReady && this.chatTypingText.trim()) {
          this.chatMessages.push({ role: 'assistant', content: this.chatTypingText });
        }
      } catch (e) {
        this.toast('error', e.message);
        if (!this.chatExtractedSystem) {
          this.chatMessages.push({ role: 'assistant', content: `오류: ${e.message}` });
        }
      } finally {
        this.chatLoading = false;
        this.chatTypingText = '';
        this.$nextTick(() => {
          const el = this.$refs.chatMessages;
          if (el) el.scrollTop = el.scrollHeight;
        });
      }
    },
    async confirmChatSystem() {
      if (!this.chatExtractedSystem) return;
      Object.assign(this.state, {
        system: this.chatExtractedSystem,
        legacy_mmd: this.chatExtractedMmd,
        legacy_drawio: this.chatExtractedDrawio,
        step: 1, analysis: null, modern: null, modern_mmd: '', modern_drawio: '',
      });
      this.diff = null;
      this.activeStep = 1;
      this.diagramTab = 'legacy';
      this.infoTab = 'summary';
      this.chatExtractedSystem = null;
      this.chatMessages = [];
      this.toast('success', `✅ ${this.state.system.name} 다이어그램 생성 완료`);
      this.$nextTick(() => this.renderDiagram());
    },

    // ── 파일 업로드 ────────────────────────────────────────────────────
    handleDrop(e) {
      this.dragging = false;
      const file = e.dataTransfer.files[0];
      if (file) this.loadFile(file);
    },
    handleFileInput(e) {
      const file = e.target.files[0];
      if (file) this.loadFile(file);
    },
    async loadFile(file) {
      this.fileName  = file.name;
      const content  = await file.text();
      this.inputText = content;
      // CodeMirror 에디터 동기화
      this._syncEditorContent(content);
    },

    // ── Ingest ─────────────────────────────────────────────────────────
    async ingest() {
      this.loading = true; this.loadingMsg = '파싱 중...'; this.streamText = '';
      try {
        const res = await fetch('/api/ingest', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ content: this.inputText, mode: 'auto' }),
        });
        if (!res.ok) { const e = await res.json(); throw new Error(e.detail || '파싱 실패'); }
        const data = await res.json();
        Object.assign(this.state, {
          system: data.system, legacy_mmd: data.legacy_mmd,
          legacy_drawio: data.legacy_drawio, step: 1,
          analysis: null, modern: null, modern_mmd: '',
        });
        this.diff = null; this.activeStep = 1;
        this.diagramTab = 'legacy'; this.infoTab = 'summary';
        this.toast('success', `✅ ${data.system.name} 파싱 완료`);
        this.$nextTick(() => this.renderDiagram());
      } catch (e) { this.toast('error', e.message); }
      finally { this.loading = false; }
    },

    // ── SSE 스트림 소비 ────────────────────────────────────────────────
    async consumeStream(url, body, onEvent) {
      const opts = body
        ? { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) }
        : { method: 'GET' };
      const res = await fetch(url, opts);
      if (!res.ok) {
        const e = await res.json().catch(() => ({ detail: `HTTP ${res.status}` }));
        throw new Error(e.detail || `HTTP ${res.status}`);
      }
      const reader = res.body.getReader();
      const dec = new TextDecoder();
      let buf = '';
      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        buf += dec.decode(value, { stream: true });
        const parts = buf.split('\n\n');
        buf = parts.pop();
        for (const part of parts) {
          if (part.startsWith('data: ')) {
            let evt;
            // JSON 파싱 실패는 무시, onEvent 내부 에러(error 이벤트 등)는 전파
            try { evt = JSON.parse(part.slice(6)); } catch { continue; }
            await onEvent(evt);
          }
        }
      }
    },

    // ── 분석 ───────────────────────────────────────────────────────────
    async startAnalysis() {
      this.loading = true; this.progress = 0; this.streamText = '';
      this.loadingMsg = '분석 준비 중...';
      try {
        await this.consumeStream('/api/analyze/stream', null, async (d) => {
          if (d.type === 'progress') { this.progress = d.pct; this.loadingMsg = d.msg; }
          else if (d.type === 'chunk') {
            this.streamText += d.text;
            this.$nextTick(() => {
              const b = this.$refs.streamBox; if (b) b.scrollTop = b.scrollHeight;
            });
          }
          else if (d.type === 'done') {
            this.state.analysis = d.result;
            this.state.analysis_rmc = d.analysis_rmc ?? null;
            this.state.multi_perspective = d.multi_perspective ?? this.state.analysis?.multi_perspective ?? null;
            this.state.step = 3;
            this.activeStep = 2;
            this._openSectionForStep(2);
            this.toast('success', '분석 완료');
          }
          else if (d.type === 'error') throw new Error(d.msg);
        });
      } catch (e) { this.toast('error', e.message); }
      finally { this.loading = false; this.streamText = ''; this.progress = 0; }
    },

    // ── 현대화 ─────────────────────────────────────────────────────────
    async startModernize() {
      if (!this.requirements.trim()) return;
      this.loading = true; this.progress = 0; this.streamText = '';
      this.loadingMsg = '현대화 설계 중...';
      try {
        await this.consumeStream(
          '/api/modernize/stream',
          { requirements: this.requirements, scenario: this.scenario || null },
          async (d) => {
            if (d.type === 'progress') { this.progress = d.pct; this.loadingMsg = d.msg; }
            else if (d.type === 'chunk') {
              this.streamText += d.text;
              this.$nextTick(() => {
                const b = this.$refs.streamBox; if (b) b.scrollTop = b.scrollHeight;
              });
            }
            else if (d.type === 'done') {
              if (d.scenario) this.scenario = d.scenario;
              Object.assign(this.state, {
                modern: d.modern, modern_mmd: d.modern_mmd,
                modern_drawio: d.modern_drawio, migration_plan: d.migration_plan,
                scenario: d.scenario, step: 4,
                design_rationale: d.design_rationale ?? null,
                design_perspective: d.design_perspective ?? null,
                migration_plan_rmc: d.migration_plan_rmc ?? null,
              });
              this.diff = computeDiff(this.state.system, this.state.modern);
              this.activeStep = 3; this.diagramTab = 'modern';
              this._openSectionForStep(3);
              const scenarioLabel = {full_replace:'전체 교체', partial:'일부 보존', additive:'신규 추가'}[d.scenario] ?? '';
              this.toast('success', `현대화 설계 완료${scenarioLabel ? ' (' + scenarioLabel + ' 시나리오)' : ''}`);
              this.$nextTick(() => this.renderDiagram());
            }
            else if (d.type === 'error') throw new Error(d.msg);
          }
        );
      } catch (e) { this.toast('error', e.message); }
      finally { this.loading = false; this.streamText = ''; this.progress = 0; }
    },

    // ── 부분 수정 ──────────────────────────────────────────────────────
    async startPatch() {
      if (!this.feedback.trim()) return;
      this.loading = true; this.progress = 0; this.streamText = '';
      this.loadingMsg = '부분 수정 적용 중...';
      try {
        await this.consumeStream(
          '/api/modernize/stream',
          { requirements: this.requirements, scenario: this.scenario || null, feedback: this.feedback },
          async (d) => {
            if (d.type === 'progress') { this.progress = d.pct; this.loadingMsg = d.msg; }
            else if (d.type === 'chunk') {
              this.streamText += d.text;
              this.$nextTick(() => {
                const b = this.$refs.streamBox; if (b) b.scrollTop = b.scrollHeight;
              });
            }
            else if (d.type === 'done') {
              if (d.scenario) this.scenario = d.scenario;
              Object.assign(this.state, {
                modern: d.modern, modern_mmd: d.modern_mmd,
                modern_drawio: d.modern_drawio, migration_plan: d.migration_plan,
                scenario: d.scenario, step: 4,
                // 부분 수정: 기존 RMC 결과 보존, 새로 생성된 경우에만 교체
                design_rationale: d.design_rationale ?? this.state.design_rationale,
                design_perspective: d.design_perspective ?? this.state.design_perspective,
                migration_plan_rmc: d.migration_plan_rmc ?? this.state.migration_plan_rmc,
              });
              this.diff = computeDiff(this.state.system, this.state.modern);
              this.feedbackMode = false;
              this.feedback = '';
              this.$nextTick(() => this.renderDiagram());
              this.toast('success', `부분 수정이 적용됐습니다`);
            }
            else if (d.type === 'error') throw new Error(d.msg);
            else if (d.type === 'warning') this.toast('warning', d.msg);
          }
        );
      } catch (e) { this.toast('error', e.message); }
      finally { this.loading = false; this.streamText = ''; this.progress = 0; }
    },

    // ── 시스템 모델 다운로드 (yaml / json / drawio) ────────────────────
    downloadSystem(step, fmt) {
      window.open(`/api/download/${step}?fmt=${fmt}`, '_blank');
    },

    // ── 다이어그램 다운로드 ────────────────────────────────────────────
    downloadDiagram(step, fmt) {
      window.open(`/api/diagram/${step}?fmt=${fmt}`, '_blank');
    },

    // ── MMD 복사 ───────────────────────────────────────────────────────
    async copyMmd(step) {
      const mmd = step === 'legacy' ? this.state.legacy_mmd : this.state.modern_mmd;
      if (!mmd) return;
      await navigator.clipboard.writeText(mmd);
      this.toast('success', 'Mermaid 코드가 복사됐습니다');
    },

    // ── 세션 초기화 ────────────────────────────────────────────────────
    async confirmReset() {
      if (!confirm('세션을 초기화하시겠습니까? 모든 데이터가 삭제됩니다.')) return;
      await fetch('/api/state', { method: 'DELETE' });
      location.reload();
    },

    // ── Toast ──────────────────────────────────────────────────────────
    toast(type, msg) {
      const id = Date.now();
      if (type === 'error') {
        console.error(`[ArchPilot] ${msg}`);
        this.toasts.push({ id, type, msg });
        // 에러는 자동으로 사라지지 않음 — 클릭으로 닫기
      } else {
        console.log(`[ArchPilot] ${msg}`);
        this.toasts.push({ id, type, msg });
        setTimeout(() => { this.toasts = this.toasts.filter(t => t.id !== id); }, 3500);
      }
    },
    dismissToast(id) {
      this.toasts = this.toasts.filter(t => t.id !== id);
    },

    // ── 리포트 패널 ────────────────────────────────────────────────────
    toggleSection(key, enabled = true) {
      if (!enabled) return;
      this.reportSections[key] = !this.reportSections[key];
    },

    async copySection(key) {
      const texts = {
        summary:      () => `시스템 요약\n컴포넌트: ${this.state.system?.components?.length ?? 0}\n연결: ${this.state.system?.connections?.length ?? 0}\n${this.state.analysis?.summary ?? ''}`,
        analysis:     () => this.state.analysis ? JSON.stringify(this.state.analysis, null, 2) : '',
        rmc_analysis:  () => this.state.analysis_rmc ? JSON.stringify(this.state.analysis_rmc, null, 2) : '',
        perspectives:         () => this.state.multi_perspective ? JSON.stringify(this.state.multi_perspective, null, 2) : '',
        design_perspectives:  () => this.state.design_perspective ? JSON.stringify(this.state.design_perspective, null, 2) : '',
        diff:         () => this.diff ? JSON.stringify(this.diff, null, 2) : '',
        rationale:    () => this.state.design_rationale ? JSON.stringify(this.state.design_rationale, null, 2) : '',
        plan:         () => this.state.migration_plan ?? '',
        plan_rmc:     () => this.state.migration_plan_rmc ? JSON.stringify(this.state.migration_plan_rmc, null, 2) : '',
      };
      const fn = texts[key];
      if (!fn) return;
      const text = fn();
      if (!text) return;
      await navigator.clipboard.writeText(text);
      this.toast('success', '클립보드에 복사됐습니다');
    },

    startPanelResize(e) {
      this._panelResizing = true;
      this._panelResizeStartX = e.clientX;
      this._panelResizeStartW = this.reportWidth;
      const onMove = (ev) => {
        if (!this._panelResizing) return;
        const delta = this._panelResizeStartX - ev.clientX;
        this.reportWidth = Math.max(220, Math.min(640, this._panelResizeStartW + delta));
      };
      const onUp = () => {
        this._panelResizing = false;
        document.removeEventListener('mousemove', onMove);
        document.removeEventListener('mouseup', onUp);
      };
      document.addEventListener('mousemove', onMove);
      document.addEventListener('mouseup', onUp);
    },

    // 파이프라인 완료 시 해당 섹션 자동 열기
    _openSectionForStep(step) {
      if (step === 2 && this.state.analysis)     { this.reportSections.analysis = true; this.reportSections.summary = true; }
      if (step === 3 && this.state.modern)        { this.reportSections.diff = true; }
      if (this.state.design_rationale)            { this.reportSections.rationale = true; }
      if (this.state.migration_plan)              { this.reportSections.plan = true; }
      if (this.state.migration_plan_rmc)          { this.reportSections.plan_rmc = true; }
      if (this.state.analysis_rmc)               { this.reportSections.rmc_analysis = true; }
      if (this.state.multi_perspective)          { this.reportSections.perspectives = true; }
      if (this.state.design_perspective)        { this.reportSections.design_perspectives = true; }
      if (!this.reportOpen)                       { this.reportOpen = true; }
    },
  };
}
</script>
</body>
</html>
