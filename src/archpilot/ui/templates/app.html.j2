<script>
// ── Mermaid 초기화 ────────────────────────────────────────────────────────
mermaid.initialize({ startOnLoad: false, theme: 'default', securityLevel: 'loose' });

// ── Diff 계산 ─────────────────────────────────────────────────────────────
function computeDiff(legacy, modern) {
  if (!legacy || !modern) return null;
  const lm = Object.fromEntries(legacy.components.map(c => [c.id, c]));
  const mm = Object.fromEntries(modern.components.map(c => [c.id, c]));
  const added = [], removed = [], modified = [], unchanged = [];
  for (const [id, c] of Object.entries(mm)) {
    if (!lm[id]) { added.push(c); continue; }
    const changed = ['type','label','host'].filter(f => lm[id][f] !== c[f]);
    if (changed.length) modified.push({ before: lm[id], after: c, changed_fields: changed });
    else unchanged.push(c);
  }
  for (const [id, c] of Object.entries(lm)) { if (!mm[id]) removed.push(c); }
  return { added, removed, modified, unchanged };
}

